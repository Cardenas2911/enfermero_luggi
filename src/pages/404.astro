---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Página no encontrada - Enfermera Bogotá">
  <div class="relative flex h-auto min-h-[80vh] w-full max-w-7xl mx-auto flex-col justify-center items-center bg-background-light dark:bg-background-dark md:shadow-2xl px-6 py-20 text-center">
    
    <div class="flex flex-col items-center max-w-lg bg-surface-light dark:bg-surface-dark p-8 md:p-14 rounded-[3rem] shadow-xl border border-slate-100 dark:border-slate-800">
      
      {/* Icono decorativo */}
      <div class="flex h-24 w-24 items-center justify-center rounded-full bg-blue-50 dark:bg-slate-800/80 text-primary mb-6 shadow-sm">
        <span class="material-symbols-outlined text-[48px]">medical_information</span>
      </div>

      <h1 class="text-primary font-black text-6xl md:text-8xl tracking-tighter mb-2">404</h1>
      <h2 class="text-slate-900 dark:text-slate-100 text-2xl md:text-3xl font-black mb-4">Página no encontrada</h2>
      
      <p class="text-slate-600 dark:text-slate-400 text-base md:text-lg mb-8 leading-relaxed">
        Lo sentimos, la página que estás buscando no existe o ha sido movida. Parece que te has extraviado en el pasillo.
      </p>

      <a href={import.meta.env.BASE_URL || "/"} class="h-14 px-8 rounded-2xl bg-primary hover:bg-primary-dark active:scale-95 text-white font-bold text-base md:text-lg flex items-center justify-center gap-2 shadow-[0_8px_30px_rgba(19,127,236,0.3)] hover:shadow-[0_8px_40px_rgba(19,127,236,0.5)] hover:-translate-y-1 transition-all">
        <span class="material-symbols-outlined text-[20px]">home</span>
        Volver al Inicio
      </a>
      
    </div>
    
  </div>
</Layout>
