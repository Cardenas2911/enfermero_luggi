---
// src/pages/index.astro
// Página principal - integra componentes React con secciones Astro existentes
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.jsx';
import Hero from '../components/Hero.jsx';
import ServicesGrid from '../components/ServicesGrid.jsx';
import WhatsAppButton from '../components/WhatsAppButton.jsx';
import MobileNav from '../components/MobileNav.jsx';
import TrustBanner from '../components/TrustBanner.jsx';
import AboutMe from '../components/AboutMe.jsx';
import Testimonials from '../components/Testimonials.jsx';
import FAQ from '../components/FAQ.jsx';
import Footer from '../components/Footer.jsx';
---

<Layout
  title="Enfermero a Domicilio en Bogotá | Luiggi Castañeda - Cuidado Profesional 24/7"
  description="Servicios de enfermería a domicilio en Bogotá. Cuidado de adulto mayor, post-operatorio, medicación y heridas. Atención humana y profesional disponible 24/7. Luiggi Castañeda, Auxiliar de Enfermería."
  professionalName="Luiggi Castañeda"
>
  {/* Ajustamos max-w-md a max-w-7xl para permitir expansión en PC */}
  <div class="relative flex h-auto w-full max-w-7xl mx-auto flex-col bg-background-light dark:bg-background-dark md:shadow-2xl md:min-h-screen">
    
    {/* ===== HEADER RESPONSIVE (React con scroll effect) ===== */}
    <Header baseUrl={import.meta.env.BASE_URL} client:load />

    {/* ===== MAIN CONTENT ===== */}
    <main class="w-full pb-24 md:pb-12 flex-1">
      
      {/* SECTION: HERO - Componente React con client:load para animaciones */}
      <div id="inicio" class="scroll-mt-24">
        <Hero
          baseUrl={import.meta.env.BASE_URL}
          client:load
        />
      </div>

      {/* TRUST BANNER: Franja de autoridad entre Hero y Servicios */}
      <TrustBanner />

      {/* SECTION: SERVICES - Grid de 6 tarjetas con animaciones framer-motion */}
      <ServicesGrid client:load />

      {/* SECTION: SOBRE MÍ - Conexión emocional con framer-motion */}
      <AboutMe baseUrl={import.meta.env.BASE_URL} client:load />

      {/* SECTION: TESTIMONIOS - Social Proof con Schema.org AggregateRating */}
      <Testimonials client:load />
      
      {/* SECTION: FAQ - Preguntas Frecuentes con acordeón y SEO JSON-LD */}
      <FAQ client:load />

      {/* SECTION: LOCATION - Zona de Cobertura Bogotá */}
      <section id="contacto" class="px-5 sm:px-8 py-20 bg-white flex flex-col items-center text-center">
        <span class="inline-block text-teal-600 font-bold uppercase text-[10px] tracking-[0.2em] mb-3">Zona de Cobertura</span>
        <h2 class="text-slate-900 text-3xl md:text-4xl font-extrabold mb-10">Atención en Bogotá & Sabana</h2>
        
        <div class="w-full max-w-4xl h-64 md:h-80 rounded-[3rem] bg-slate-100 relative overflow-hidden shadow-2xl border-8 border-white group">
          <div class="absolute inset-0 bg-cover bg-center transition-transform duration-700 group-hover:scale-110 grayscale-[0.3] group-hover:grayscale-0" style={`background-image: url("${import.meta.env.BASE_URL}/assets/mapa_bogota.png");`}></div>
          <div class="absolute inset-0 bg-slate-900/10 flex items-center justify-center backdrop-blur-[2px]">
            <div class="bg-white/95 backdrop-blur-md px-8 py-4 rounded-3xl shadow-2xl flex items-center gap-4 text-slate-900 border border-white/20">
              <div class="h-10 w-10 flex items-center justify-center bg-teal-500 text-white rounded-full">
                <span class="material-symbols-outlined text-[24px]">location_on</span>
              </div>
              <div class="text-left">
                <p class="text-xs font-bold text-teal-600 uppercase tracking-widest leading-none mb-1">Disponible en</p>
                <p class="text-lg md:text-xl font-black leading-none">Bogotá D.C. & Sabana</p>
              </div>
            </div>
          </div>
        </div>
        
        <p class="text-slate-500 text-sm font-medium mt-10 max-w-lg">
          ¿Atención en Chía, Cajicá o Soacha? <br class="hidden sm:block" />
          <a href="#inicio" class="text-teal-600 font-bold hover:underline transition-all">Consúltame por WhatsApp directamente →</a>
        </p>
      </section>

    </main>

    {/* ===== FOOTER PREMIUM: Branding + NAP SEO + Legal ===== */}
    <Footer client:load />

    {/* ===== MOBILE NAV ESTILO APP (Solo en móvil) ===== */}
    <MobileNav client:load />
    
  </div>

  {/* Botón flotante de WhatsApp (visible en desktop, sobre el nav móvil en mobile) */}
  <WhatsAppButton
    phoneNumber="573507871980"
    message="Hola, Luiggi! Necesito una valoración de enfermería en Bogotá. 🩺"
    client:load
  />
</Layout>
